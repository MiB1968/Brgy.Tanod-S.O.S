rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 0. GLOBAL SAFETY NET
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // PHASE 3: PRIMITIVES
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Roles - Look up from trusted 'users' collection
    function getRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin() { return isVerified() && (getRole() == 'admin' || getRole() == 'superadmin' || request.auth.token.email == 'rubenlleg12@gmail.com' || request.auth.token.email == 'ronniecantuba420@gmail.com'); }
    function isTanod() { return isVerified() && (getRole() == 'tanod' || isAdmin()); }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // ==========================================
    // 1. USERS COLLECTION
    // ==========================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role', 'email']) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.role == 'resident' &&
             data.email == request.auth.token.email;
    }

    match /users/{userId} {
      allow get: if isVerified();
      allow list: if isAdmin();
      allow create: if isVerified() && isValidUser(incoming());
      allow update: if isVerified() && (
        (isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone'])) ||
        isAdmin()
      );
    }

    // ==========================================
    // 2. RESIDENTS (Registration Data)
    // ==========================================
    function isValidResident(data) {
      return data.keys().hasAll(['fullName', 'mobileNumber', 'gpsLat', 'gpsLng', 'status', 'registeredAt', 'uid']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 200 &&
             data.status == 'pending' &&
             data.registeredAt == request.time;
    }

    match /residents/{residentId} {
      allow get: if isVerified() && (isTanod() || isOwner(residentId));
      allow list: if isTanod();
      allow create: if isVerified() && isValidResident(incoming()) && isValidId(residentId);
      allow update: if isVerified() && (
        (isOwner(residentId) && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'mobileNumber', 'idPhotoUrl', 'selfieUrl'])) ||
        (isTanod() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'approvedAt']))
      );
    }

    // ==========================================
    // 3. EMERGENCY ALERTS (SOS)
    // ==========================================
    function isValidAlert(data) {
      return data.keys().hasAll(['residentId', 'residentName', 'type', 'status', 'timestamp', 'location']) &&
             data.residentId == request.auth.uid &&
             data.type is string && data.type.size() <= 50 &&
             data.status == 'pending' &&
             data.timestamp == request.time &&
             data.location is map && data.location.lat is number && data.location.lng is number;
    }

    match /alerts/{alertId} {
      allow get: if isVerified();
      allow list: if isVerified() && (isTanod() || resource.data.residentId == request.auth.uid);
      allow create: if isVerified() && isValidAlert(incoming()) && isValidId(alertId);
      allow update: if isVerified() && (
        // Resident cancels their own alert
        (isOwner(existing().residentId) && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['status']) && incoming().status == 'cancelled') ||
        // Tanod responds or resolves
        (isTanod() && (
          (existing().status in ['pending', 'responding'] && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'respondedBy', 'resolutionNotes', 'resolvedAt']))
        ))
      );
      allow delete: if isAdmin();
    }

    // ==========================================
    // 4. TANODS (Status & Real-time GPS)
    // ==========================================
    match /tanods/{tanodId} {
      allow read: if isVerified();
      allow write: if isTanod() && isOwner(tanodId);
    }

    // ==========================================
    // 5. PATROLS (Live Tracking)
    // ==========================================
    match /patrols/{patrolId} {
      allow read: if isVerified();
      allow create: if isTanod() && incoming().tanodId == request.auth.uid;
      allow update: if isTanod() && existing().tanodId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ==========================================
    // 6. SYSTEM (Siren, etc)
    // ==========================================
    match /system/{docId} {
      allow read: if isVerified();
      allow update: if isTanod() && incoming().diff(existing()).affectedKeys().hasOnly(['sirenActive', 'sirenTriggeredBy', 'sirenTriggeredAt']);
    }

    // ==========================================
    // 7. ACTIVITY LOGS & SESSIONS
    // ==========================================
    match /tanod_activity_logs/{logId} {
      allow read: if isTanod();
      allow create: if isTanod() && incoming().tanodId == request.auth.uid;
    }

    match /patrol_sessions/{sessionId} {
      allow read: if isTanod();
      allow create, update: if isTanod() && incoming().tanodId == request.auth.uid;
    }
    
    // ==========================================
    // 8. TEST CONNECTION
    // ==========================================
    match /test/connection {
      allow read: if true;
    }
  }
}
