# ==================== Firecrawl (Web Scraping & AI) ====================
VITE_FIRECRAWL_API_KEY=fc-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Server Configuration
NODE_ENV=development
JWT_SECRET=DEV_ONLY_jwt_secret_change_before_deploy_32chars
DATABASE_URL=
COCKROACH_URL=
CORS_ORIGIN=

# AI Services
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
MY_GEMINI_SECRET=
GUARDIAN_AI_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
ANTHROPIC_API_KEY=

# Voice Services (Optional)
VITE_ORS_API_KEY=your_ors_key_here
ELEVENLABS_API_KEY=
JARVIS_VOICE_ID=
FISHAUDIO_API_KEY=

# Admin Bootstrap
VITE_MASTER_EMAILS=yourpersonal@gmail.com,ruben.yourbarangay@gmail.com
VITE_MASTER_EMAIL=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# Firebase Admin (Server-side — used to verify Google ID tokens)
FIREBASE_PROJECT_ID=demo-project

# Firebase Client (Vite — used by src/lib/firebase.ts)
# Get these from your Firebase Console → Project Settings → Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FCM_VAPID_KEY=

# QwenPaw Agent Integrations
QWENPAW_URL=http://localhost:8088
DISPATCHER_AGENT_ID=your-dispatcher-id
REPORTER_AGENT_ID=your-reporter-id

# Twilio SMS Fallback
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+63xxxxxxxxxx
TWILIO_SMS_WEBHOOK_URL=https://yourdomain.com/api/webhooks/sms-status

# SMS Settings
SMS_FALLBACK_ENABLED=true
SMS_FALLBACK_DELAY_MINUTES=5
MAX_SMS_RECIPIENTS_PER_ALERT=10
