# ── REQUIRED in production (server will refuse to start without these) ────────
JWT_SECRET=your_long_random_secret_minimum_32_characters_here
DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=verify-full
CORS_ORIGIN=https://your-deployed-app-url.com
VITE_API_SECRET_KEY=your_api_secret_key_here

# ── Optional but strongly recommended ──────────────────────────────────────────
COCKROACH_URL=
NODE_ENV=production
PORT=3000

# ── AI / Voice integrations ────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GUARDIAN_AI_KEY=YOUR_GEMINI_API_KEY_HERE
ELEVENLABS_API_KEYS=ek_xxx1,ek_xxx2
JARVIS_VOICE_ID=pNInz6obpgDQGcFmaJgB
FISHAUDIO_API_KEYS=fa_xxx1,fa_xxx2
FISH_AUDIO_VOICE_ID=7fcf27b7b14041fd8489f074d2091475

# ── SMS ────────────────────────────────────────────────────────────────────────
SEMAPHORE_API_KEY=

# ── First-run admin bootstrap only ─────────────────────────────────────────────
# Required only if no admin account exists yet.
ADMIN_BOOTSTRAP_EMAIL=admin@yourbarangay.gov.ph
ADMIN_BOOTSTRAP_PASSWORD=ChangeThisImmediately!

# ── Firebase ───────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
