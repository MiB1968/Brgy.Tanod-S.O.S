# =============================================================================
# Brgy. Tanod S.O.S — Environment Variables
# Copy this file to .env and fill in your values before running.
# NEVER commit the real .env file to git.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# JWT signing key — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production. The server will warn loudly and use a random fallback
# (invalidating all sessions on restart) if this is not set.
JWT_SECRET=

# AES-256 encryption key for resident PII (blood type, meds, allergies).
# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, the server generates a random key on startup — PII encrypted in
# one session CANNOT be decrypted after a restart. Set this before first use.
ENCRYPTION_KEY=

# Database connection string (CockroachDB / PostgreSQL)
DATABASE_URL=
COCKROACH_URL=

# ── API Key (system-to-system auth) ──────────────────────────────────────────
# Used by the x-api-key header path in auth middleware.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set API_KEY_ROLE=admin to elevate API key requests to admin role (default: tanod).
API_KEY=
API_KEY_ROLE=tanod

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins in production.
# Example: CORS_ORIGIN=https://brgy.yourbarangay.gov.ph,https://admin.yourbarangay.gov.ph
# If empty in production, only same-origin requests will be allowed.
CORS_ORIGIN=

# ── Firebase Admin (server-side) ──────────────────────────────────────────────
FIREBASE_PROJECT_ID=demo-project

# ── Firebase Client (Vite build — used by src/lib/firebase.ts) ───────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FCM_VAPID_KEY=
VITE_FIREBASE_VAPID_KEY=

# ReCAPTCHA v3 site key for Firebase App Check
VITE_RECAPTCHA_SITE_KEY=6LcJthAtAAAAAPPGg7v3OjaVGRjhxt95GYtiP9wl
# Service account/Server-side reCAPTCHA secret key (Required in backend env)
RECAPTCHA_SECRET_KEY=

# ── Master Admin Emails ───────────────────────────────────────────────────────
# Comma-separated emails that get super_admin role elevation on both server
# and client. NEVER hardcode emails in source code — use this env var.
# Example: VITE_MASTER_EMAILS=youremail@gmail.com,backup@yourdomain.com
# NOTE: On the server, this is read as process.env.VITE_MASTER_EMAILS.
#       On the client (Vite), it is read as import.meta.env.VITE_MASTER_EMAILS.
VITE_MASTER_EMAILS=
VITE_MASTER_EMAIL=

# ── Admin Bootstrap ───────────────────────────────────────────────────────────
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=

# ── AI Services ───────────────────────────────────────────────────────────────
# Primary Gemini API key. Used by aiService.ts and voiceAssistantService.ts.
GEMINI_API_KEY=

# FIX: GEMINI_API_KEY_NEW — was missing from .env.example but referenced in code.
# Use this to rotate keys without downtime: aiService.ts checks _NEW first,
# falls back to GEMINI_API_KEY. Set the new key here, verify, then update GEMINI_API_KEY.
GEMINI_API_KEY_NEW=

MY_GEMINI_SECRET=
GUARDIAN_AI_KEY=

# Gemini model override (overrides aiModels.ts defaults for all tiers).
# Leave blank to use the built-in tier routing (recommended).
# Valid values: gemini-2.0-flash, gemini-2.0-flash-lite, gemini-2.5-pro-preview-06-05
GEMINI_MODEL=

# OpenRouter / other model providers
# ANTHROPIC_API_KEY=

# ── Firecrawl (Web Scraping) ──────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Voice Services ────────────────────────────────────────────────────────────
VITE_ORS_API_KEY=your_ors_key_here
ELEVENLABS_API_KEY=
ELEVENLABS_API_KEYS=
JARVIS_VOICE_ID=
FISHAUDIO_API_KEY=
FISHAUDIO_API_KEYS=

# ── Twilio SMS Fallback ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+63xxxxxxxxxx
TWILIO_SMS_WEBHOOK_URL=https://yourdomain.com/api/webhooks/sms-status
SMS_FALLBACK_ENABLED=true
SMS_FALLBACK_DELAY_MINUTES=5
MAX_SMS_RECIPIENTS_PER_ALERT=10

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Required to validate incoming Telegram webhook calls.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then register your webhook with this secret:
#   curl -X POST https://api.telegram.org/bot<TOKEN>/setWebhook \
#     -H "Content-Type: application/json" \
#     -d '{"url":"https://yourdomain.com/api/webhooks/telegram","secret_token":"<value>"}'
TELEGRAM_WEBHOOK_SECRET=

# ── QwenPaw Agent ─────────────────────────────────────────────────────────────
QWENPAW_URL=http://localhost:8088
DISPATCHER_AGENT_ID=your-dispatcher-id
REPORTER_AGENT_ID=your-reporter-id

# ── Sentry Error Tracking ─────────────────────────────────────────────────────
VITE_SENTRY_DSN=
SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
APP_VERSION=1.0.0

# ── App URL (for Telegram webhook registration) ───────────────────────────────
APP_URL=https://yourdomain.com
