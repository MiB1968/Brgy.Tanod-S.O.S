rules_version = '2';

// ---------------------------------------------------------------------------
// FIX BATCH — MED-01 + CRIT-01 (Firestore layer)
//
// Changes from original:
//
//   MED-01 — selfHealingSuperAdmin() function removed.
//     The original rules allowed the hardcoded master email to write
//     `role: 'super_admin'` to their own Firestore user document from the
//     client side. This contradicted the stated design intent ("role is
//     immutable from the client") and mirrored the CRIT-01 server-side
//     backdoor at the Firestore layer. Removed entirely.
//
//   CRIT-01 (Firestore layer) — isMasterAdminEmail() function removed.
//     The personal email 'rubenlleg12@gmail.com' was hardcoded in this
//     function. It is no longer referenced anywhere in these rules.
//
//   Role elevation is now exclusively handled by the setUserRole Cloud
//   Function (via Firebase Admin SDK). No client can write or elevate the
//   `role` field under any circumstances.
//
// All other rules (alerts, locations, patrols, broadcasts, audit logs,
// deny-all fallback) are unchanged.
// ---------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // Role is read from Firebase custom claims (set server-side by Cloud Functions).
    // This is the ONLY trusted source of role. Firestore profile.role is for
    // display only; never trust it for access control.
    function hasRole(roles) {
      return isAuthenticated() && request.auth.token.role in roles;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdminOrAbove() {
      return hasRole(['admin', 'super_admin']);
    }

    function isTanodOrAbove() {
      return hasRole(['tanod', 'admin', 'super_admin']);
    }

    // MED-01 + CRIT-01 FIX: isMasterAdminEmail() and selfHealingSuperAdmin()
    // have been removed. No email address is hardcoded in these rules.
    // Role changes are exclusively handled by Cloud Functions via Admin SDK.

    // FIX: Prevent clients from writing the `role` field.
    // The incoming write must NOT include a `role` field,
    // or the existing role and incoming role must be identical.
    function roleIsUnchanged() {
      return !('role' in request.resource.data) ||
             request.resource.data.role == resource.data.role;
    }

    // ── Users ───────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdminOrAbove();

      // Owners can update their own profile but CANNOT change their role.
      // MED-01 FIX: selfHealingSuperAdmin() exception removed.
      allow update: if isOwner(userId) && roleIsUnchanged();

      // Admins can update any profile field EXCEPT role.
      // Role changes are handled exclusively by the setUserRole Cloud Function.
      allow update: if isAdminOrAbove() && roleIsUnchanged();

      // New user document creation: role must be 'resident' or absent.
      // MED-01 FIX: selfHealingSuperAdmin() exception removed.
      // Super admin accounts are bootstrapped via Cloud Functions, not client writes.
      allow create: if isOwner(userId) &&
                    (!('role' in request.resource.data) ||
                     request.resource.data.role == 'resident');

      allow delete: if isAdminOrAbove();
    }

    // ── Residents ───────────────────────────────────────────────────────────
    match /residents/{residentId} {
      allow read: if isOwner(residentId) || isTanodOrAbove();
      allow update: if isOwner(residentId) || isAdminOrAbove();
      allow create: if isAuthenticated();
      allow delete: if isAdminOrAbove();
    }

    // ── Alerts ──────────────────────────────────────────────────────────────
    match /alerts/{alertId} {
      allow create: if isAuthenticated() &&
                    request.resource.data.reportedBy == request.auth.uid &&
                    request.resource.data.location is map &&
                    request.resource.data.type is string &&
                    (request.auth.token.email_verified == true || request.auth.token.role in ['resident', 'tanod', 'admin', 'super_admin']);

      allow read: if isAuthenticated() &&
                  (isTanodOrAbove() || resource.data.reportedBy == request.auth.uid);

      // Only assigned Tanod, Admins, or any Tanod (if accepting a pending alert) can update
      allow update: if isAuthenticated() && (
                    isAdminOrAbove() ||
                    (hasRole(['tanod']) && (
                      resource.data.status == 'pending' ||
                      resource.data.assignedTo == request.auth.uid
                    ))
                  );
      allow delete: if isAdminOrAbove();
    }

    // ── Tanod Locations ─────────────────────────────────────────────────────
    match /tanod_locations/{userId} {
      // Tanod can only write their OWN location document.
      allow write: if isAuthenticated() &&
                   request.auth.uid == userId &&
                   isTanodOrAbove();
      // Authenticated users (residents and tanods) can read active locations to view responders on the live map.
      allow read: if isAuthenticated();
    }

    // ── Patrols & Logs ──────────────────────────────────────────────────────
    match /patrols/{document=**} {
      allow read, write: if isTanodOrAbove();
    }

    match /tanod_logs/{document=**} {
      allow read, write: if isTanodOrAbove();
    }

    // ── System Broadcasts ───────────────────────────────────────────────────
    match /system_broadcasts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrAbove();
    }

    // ── Audit Logs (append-only via Cloud Functions) ─────────────────────────
    match /audit_logs/{document=**} {
      allow read: if isAdminOrAbove();
      // Clients cannot write audit logs — only Cloud Functions via Admin SDK.
      allow write: if false;
    }

    // ── Deny-all fallback ───────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
