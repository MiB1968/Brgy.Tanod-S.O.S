rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    
    function isMasterAdmin() { 
      return isSignedIn() && request.auth.token.email == 'rubenlleg12@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role-based helpers using get() lookups
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isMasterAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'admin' || getUserRole() == 'superadmin'));
    }

    function isTanod() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && (getUserRole() == 'tanod'));
    }

    // ==========================================
    // COLLECTION RULES
    // ==========================================

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || isOwner(userId);
    }

    // Resident Enrollment Details
    match /residents/{userId} {
      allow read: if isTanod() || isOwner(userId);
      allow write: if isMasterAdmin() || isOwner(userId);
    }

    // Emergency Alerts
    match /alerts/{alertId} {
      // Residents can only list their own alerts, Tanods/Admins can see everything
      allow read: if isSignedIn() && (isTanod() || resource.data.residentId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isTanod() || resource.data.residentId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Incidents (Archived/Logged alerts/reports)
    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow write: if isTanod();
    }

    // Patrol Tracking
    match /patrols/{patrolId} {
      allow read: if isSignedIn();
      allow write: if isTanod();
    }

    // Shifts & Scheduling
    match /shifts/{shiftId} {
      allow read: if isSignedIn();
      allow write: if isTanod(); // Tanods need to confirm/decline, Admins create
    }

    // Tanod Data (GPS Mirror)
    match /tanods/{tanodId} {
      allow read: if isSignedIn();
      allow write: if isTanod() || isOwner(tanodId);
    }

    // System Config & Global Siren
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isTanod(); // Both Admins and Tanods can toggle siren
    }

    // Audit Logs (Missing previously)
    match /audit_logs/{logId} {
      allow read: if isTanod();
      allow write: if isTanod();
    }

    // ==========================================
    // VALIDATION HELPERS
    // ==========================================
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['tanodId', 'tanodName', 'type', 'details', 'timestamp']) &&
             data.tanodId is string && data.tanodId == request.auth.uid &&
             data.tanodName is string && data.tanodName.size() <= 100 &&
             data.type in ['duty_start', 'duty_end', 'alert_response', 'patrol_marker', 'status_change'] &&
             data.timestamp is string;
    }

    function isValidPatrolSession(data) {
      return data.keys().hasAll(['tanodId', 'tanodName', 'startTime', 'route']) &&
             data.tanodId is string && data.tanodId == request.auth.uid &&
             data.tanodName is string &&
             data.startTime is string &&
             data.route is list && data.route.size() <= 5000;
    }

    // Tanod Activity Logs
    match /tanod_activity_logs/{logId} {
      // Admins see all, Tanods only see their own (if they query correctly)
      allow read: if isAdmin() || (isTanod() && resource.data.tanodId == request.auth.uid);
      allow create: if isTanod() && isValidActivityLog(incoming());
      allow update, delete: if isAdmin();
    }

    // Patrol Sessions
    match /patrol_sessions/{sessionId} {
      allow read: if isAdmin() || (isTanod() && resource.data.tanodId == request.auth.uid);
      allow create: if isTanod() && isValidPatrolSession(incoming());
      allow update: if isTanod() && incoming().tanodId == existing().tanodId && incoming().tanodId == request.auth.uid;
      allow delete: if isAdmin();
    }
    
    // System Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Global Catch-all (Deny anything else)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
