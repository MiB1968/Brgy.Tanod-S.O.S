rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.role in ['tanod', 'admin', 'superadmin'];
    }

    // SOS Alerts
    match /alerts/{alertId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.role in ['tanod', 'admin', 'superadmin']
      );
      allow update: if request.auth != null && request.auth.token.role in ['tanod', 'admin', 'superadmin'];
    }

    // Incidents
    match /incidents/{incidentId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.role in ['tanod', 'admin', 'superadmin'];
    }

    // Tanod Live Locations
    match /tanodLocations/{tanodId} {
      allow create, update: if request.auth != null && request.auth.uid == tanodId;
      allow read: if request.auth != null && request.auth.token.role in ['tanod', 'admin', 'superadmin'];
    }

    // SMS Logs
    match /smsLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.role in ['admin', 'superadmin'];
    }

    // System Settings
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'superadmin'];
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
