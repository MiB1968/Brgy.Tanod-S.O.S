rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && 
                      (request.auth.uid == userId || 
                       request.auth.token.role == "superadmin" ||
                       request.auth.token.role == "admin");
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Incidents / Alerts
    match /alerts/{alertId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null;
    }

    // Allow authenticated access to other operational collections 
    // to prevent app breakage while adhering to user's shift mapping.
    match /patrols/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /system_broadcasts/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /tanod_logs/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /sos_messages/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Default fallback - deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
