rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL HELPERS
    // ==========================================
    function isSignedIn() { return request.auth != null; }
    
    function isMasterAdmin() { 
      return isSignedIn() && request.auth.token.email == 'rubenlleg12@gmail.com';
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() { 
      return isSignedIn() && (
        isMasterAdmin() || 
        (getUserData() != null && getUserData().role == 'admin')
      );
    }
    
    function isTanod() { 
      return isSignedIn() && (
        isAdmin() || 
        (getUserData() != null && getUserData().role == 'tanod')
      );
    }

    // ==========================================
    // SECURITY RULES (Simplified to avoid blocking Prototype testing)
    // ==========================================

    match /{document=**} {
      allow read, write: if isMasterAdmin();
    }
    match /report_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isTanod() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update: if isTanod() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }
    match /users/{userId} {
      allow read: if isTanod() || request.auth.uid == userId;
      allow write: if isMasterAdmin() || request.auth.uid == userId;
    }
    match /tanods/{tanodId} {
      allow read: if isSignedIn();
      allow write: if isMasterAdmin() || request.auth.uid == tanodId;
    }
    match /test/connection {
      allow read: if true;
    }
  }
}
