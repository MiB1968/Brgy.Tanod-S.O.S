rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Safety Net ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Global Helpers ---
    function isSignedIn() { 
      return request.auth != null && request.auth.token.email_verified == true; 
    }
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in ['rubenlleg12@gmail.com', 'ronniecantuba420@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'])
      );
    }
    
    function isTanod() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'rubenlleg12@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'tanod')
      );
    }

    function isTanodOrAdmin() {
      return isAdmin() || isTanod();
    }

    // --- Users Collection ---
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid
             && data.email is string && data.email.size() <= 128
             && data.role is string && data.role in ['resident', 'tanod', 'admin', 'superadmin']
             && data.status is string && data.status in ['pending', 'approved', 'rejected', 'Available', 'On Patrol', 'Responding', 'Offline', 'On-Duty'];
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (userId == request.auth.uid || isTanodOrAdmin());
      allow list: if isSignedIn() && isTanodOrAdmin();
      
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == 'resident';
      allow update: if isSignedIn() && (
        // Self-update limited fields
        (userId == request.auth.uid && (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'name', 'phone', 'address', 'lastActive', 'photoURL', 'activeAlertId', 'geohash', 'updatedAt', 'lat', 'lng', 'lastSOSAt', 'isLocationSharingEnabled'])
        )) ||
        // Admin update roles
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'status', 'rejectionReason', 'updatedAt', 'activeAlertId']))
      );
    }

    // --- Residents Collection (Detailed PII) ---
    match /residents/{residentId} {
      allow get: if isSignedIn() && (residentId == request.auth.uid || isTanodOrAdmin());
      allow list: if isSignedIn() && isTanodOrAdmin();
      allow write: if isSignedIn() && residentId == request.auth.uid;
    }

    // --- Alerts Collection (SOS) ---
    function isValidAlert(data) {
      return data.residentId is string 
             && data.status is string && data.status in ['pending', 'responding', 'resolved', 'cancelled']
             && (data.timestamp is string || data.timestamp is timestamp)
             && (data.timestamp is timestamp ? data.timestamp <= request.time : (data.timestamp is string && data.timestamp.size() <= 30))
             && data.residentName is string && data.residentName.size() <= 100
             && (!("customMessage" in data) || (data.customMessage is string && data.customMessage.size() <= 1000))
             && (data.type is string && data.type.size() <= 50);
    }

    match /alerts/{alertId} {
      allow get: if isSignedIn() && (resource.data.residentId == request.auth.uid || isTanodOrAdmin());
      allow list: if isSignedIn() && (isTanodOrAdmin() || resource.data.residentId == request.auth.uid);
      
      allow create: if isSignedIn() 
                    && isValidId(alertId)
                    && isValidAlert(incoming())
                    && incoming().residentId == request.auth.uid;
                    
      allow update: if isSignedIn() && isValidAlert(incoming()) && (
        // Action: Resident abort/update
        (existing().residentId == request.auth.uid && incoming().residentId == existing().residentId && (
           // Terminal lock
           existing().status != 'resolved' && existing().status != 'cancelled' &&
           // Cannot shortcut to resolved
           !(existing().status == 'pending' && incoming().status == 'resolved') &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'location', 'type', 'customMessage', 'updatedAt', 'isManualLocation'])
        )) ||
        // Action: Tanod response
        (isTanodOrAdmin() && incoming().residentId == existing().residentId && (
           existing().status != 'resolved' && existing().status != 'cancelled' &&
           // Cannot shortcut to resolved
           !(existing().status == 'pending' && incoming().status == 'resolved') &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'assignedTo', 'assignedToName', 'respondedBy', 'respondedByName', 'respondedAt', 'resolvedAt', 'resolutionNotes', 'responderNotes', 'aiAnalysis', 'updatedAt'])
        )) ||
        // Master override for admins
        isAdmin()
      );

      // --- Tactical SOS Chat ---
      match /messages/{messageId} {
        allow list, get: if isSignedIn() && (
          get(/databases/$(database)/documents/alerts/$(alertId)).data.residentId == request.auth.uid ||
          isTanodOrAdmin()
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/alerts/$(alertId)).data.residentId == request.auth.uid ||
          isTanodOrAdmin()
        ) && incoming().senderId == request.auth.uid
          && incoming().message is string && incoming().message.size() <= 2000;
      }
    }

    // --- Incidents (Archives) ---
    function isValidIncident(data) {
      return data.tanodId is string 
             && data.status is string
             && data.type is string
             && (data.description is string && data.description.size() <= 3000);
    }

    match /incidents/{incidentId} {
      allow get: if isSignedIn() && (resource.data.tanodId == request.auth.uid || isTanodOrAdmin());
      allow list: if isSignedIn() && isTanodOrAdmin();
      allow create: if isSignedIn() && isTanodOrAdmin() && isValidIncident(incoming());
      allow update: if isAdmin();
      allow delete: if false;
    }

    // --- Live Patrols ---
    match /patrols/{tanodId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (tanodId == request.auth.uid || isAdmin());
    }

    // --- System Status & Broadcasts ---
    match /system/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    function isValidBroadcast(data) {
      return data.message is string && data.message.size() <= 2000
             && data.type is string
             && (data.timestamp is string || data.timestamp is timestamp);
    }

    match /broadcasts/{broadcastId} {
      allow get: if isSignedIn() && isValidId(broadcastId);
      allow list: if isSignedIn();
      allow create, update: if isAdmin() && isValidBroadcast(incoming());
      allow delete: if isAdmin();
    }

    match /system_broadcasts/{broadcastId} {
      allow get: if isSignedIn() && isValidId(broadcastId);
      allow list: if isSignedIn();
      allow create, update: if isAdmin() && isValidBroadcast(incoming());
      allow delete: if isAdmin();
    }

    // --- Shifts & Patrols ---
    function isValidShift(data) {
      return data.tanodId is string && data.tanodName is string
             && (data.startTime is string || data.startTime is timestamp) 
             && (data.endTime is string || data.endTime is timestamp)
             && data.status is string;
    }

    match /shifts/{shiftId} {
      allow get: if isSignedIn() && isValidId(shiftId);
      allow list: if isSignedIn();
      allow create: if isAdmin() && isValidShift(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isTanod() && existing().tanodId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      );
      allow delete: if isAdmin();
    }

    match /patrol_sessions/{sessionId} {
      allow read: if isSignedIn() && isTanodOrAdmin();
      allow create: if isSignedIn() && isTanod() && incoming().tanodId == request.auth.uid;
      allow update: if isAdmin() || (isTanod() && existing().tanodId == request.auth.uid);
    }

    match /tanod_activity_logs/{logId} {
      allow read: if isSignedIn() && isTanodOrAdmin();
      allow create: if isSignedIn() && isTanod() && incoming().tanodId == request.auth.uid;
    }

    // --- Witness Circle ---
    match /witness_invites/{inviteId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.witnessUserId == request.auth.uid || isTanodOrAdmin());
      allow update: if isSignedIn() && resource.data.witnessUserId == request.auth.uid;
    }

    match /system_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
