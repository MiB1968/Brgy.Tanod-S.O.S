rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() { return request.auth != null; }
    function isRole(roles) { return isAuthenticated() && request.auth.token.role in roles; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }
    function isAdminOrAbove() { return isRole(['admin', 'superadmin']); }
    function isTanodOrAbove() { return isRole(['tanod', 'admin', 'superadmin']); }

    match /users/{userId} {
      allow read, update: if isOwner(userId) || isAdminOrAbove();
      allow create: if isOwner(userId);
      allow delete: if isAdminOrAbove();
    }

    match /residents/{residentId} {
      allow read: if isOwner(residentId) || isTanodOrAbove();
      allow update: if isOwner(residentId) || isAdminOrAbove();
      allow create: if isAuthenticated();
      allow delete: if isAdminOrAbove();
    }

    match /alerts/{alertId} {
      allow create: if isAuthenticated() &&
                    request.resource.data.reportedBy == request.auth.uid &&
                    request.resource.data.location is map &&
                    request.resource.data.type is string &&
                    request.resource.data.timestamp is timestamp;

      allow read: if isAuthenticated() && 
                  (isTanodOrAbove() || resource.data.reportedBy == request.auth.uid);
      allow update: if isTanodOrAbove();
      allow delete: if isAdminOrAbove();
    }

    match /locations/{userId} {
      allow write: if isAuthenticated() && request.auth.uid == userId && isTanodOrAbove();
      allow read: if isTanodOrAbove();
    }

    match /patrols/{document=**} {
      allow read, write: if isTanodOrAbove();
    }

    match /tanod_logs/{document=**} {
      allow read, write: if isTanodOrAbove();
    }

    match /system_broadcasts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdminOrAbove();
    }

    match /audit_logs/{document=**} {
      allow read: if isAdminOrAbove();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
