rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return request.auth.token.role == "superadmin";
    }

    function hasRole(role) {
      return isAuthenticated() && 
             (request.auth.token.role == role || isSuperAdmin());
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if request.auth.uid == userId || hasRole("admin") || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Alerts / SOS (core emergency data)
    match /alerts/{alertId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();  // Residents create their own
      allow update: if hasRole("tanod") || hasRole("admin") || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Incidents, responses, etc.
    match /incidents/{incidentId} {
      allow read, create, update: if hasRole("tanod") || hasRole("admin") || isSuperAdmin();
    }

    // Audit logs - write only by system
    match /audit_logs/{logId} {
      allow read: if hasRole("admin") || isSuperAdmin();
      allow create: if isAuthenticated();  // System writes
      allow update, delete: if isSuperAdmin();
    }
    
    // Other collections (patrols, broadcasts, etc.)
    match /patrols/{document=**} {
      allow read, write: if hasRole("tanod") || hasRole("admin") || isSuperAdmin();
    }
    match /system_broadcasts/{document=**} {
      allow read: if isAuthenticated();
      allow write: if hasRole("admin") || isSuperAdmin();
    }
    match /tanod_logs/{document=**} {
        allow read: if hasRole("admin") || isSuperAdmin();
        allow write: if hasRole("tanod") || hasRole("admin") || isSuperAdmin();
    }
    match /sos_messages/{document=**} {
        allow read, write: if hasRole("tanod") || hasRole("admin") || isSuperAdmin();
    }
    match /location_logs/{document=**} {
        allow read: if hasRole("admin") || isSuperAdmin();
        allow write: if hasRole("tanod") || hasRole("admin") || isSuperAdmin();
    }

    // Catch-all - deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
