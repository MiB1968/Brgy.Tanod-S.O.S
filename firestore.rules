rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Default-Deny Catch-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Alerts Collection ---
    function isValidAlert(data) {
      return data.residentId is string 
             && data.residentId == request.auth.uid
             && data.status is string
             && data.timestamp is string 
             && data.residentName is string 
             && data.residentName.size() >= 1 && data.residentName.size() <= 100;
    }

    match /alerts/{alertId} {
      allow create: if isSignedIn() 
                    && isValidId(alertId)
                    && isValidAlert(incoming())
                    && incoming().keys().hasAll(['residentId', 'status', 'timestamp', 'residentName'])
                    && incoming().keys().size() == 4;
      allow read: if isSignedIn() && resource.data.residentId == request.auth.uid;
      allow update, delete: if false; 
    }

    // --- Incidents Collection ---
    function isValidIncident(data) {
        return data.tanodId is string 
               && data.tanodId == request.auth.uid
               && data.status is string
               && data.type is string
               && data.description is string
               && data.location is string
               && data.timestamp is string
               && data.tanodName is string
               && data.description.size() >= 1 && data.description.size() <= 1000
               && data.location.size() >= 1 && data.location.size() <= 200;
    }

    match /incidents/{incidentId} {
      allow create: if isSignedIn() 
                    && isValidId(incidentId)
                    && isValidIncident(incoming())
                    && incoming().keys().hasAll(['id', 'tanodId', 'tanodName', 'timestamp', 'location', 'type', 'description', 'status'])
                    && incoming().keys().size() >= 8;
      allow update: if isSignedIn()
                    && isValidIncident(incoming())
                    && incoming().tanodId == existing().tanodId // Immutable
                    && existing().status != 'completed' // Pillar 3: Terminal State Locking
                    && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'description', 'actionsTaken', 'personsInvolved', 'resolvedAt']);
      allow read: if isSignedIn() && resource.data.tanodId == request.auth.uid;
      allow delete: if false; 
    }

    // --- Patrols Collection ---
    function isValidPatrol(data) {
        return data.tanodId is string
               && data.tanodId == request.auth.uid
               && data.tanodName is string
               && data.location is map
               && data.location.lat is float
               && data.location.lng is float
               && data.isActive is bool
               && data.lastUpdate is string;
    }

    match /patrols/{tanodId} {
      allow create: if isSignedIn()
                            && isValidId(tanodId)
                            && tanodId == request.auth.uid
                            && isValidPatrol(incoming())
                            && incoming().keys().hasAll(['id', 'tanodId', 'tanodName', 'location', 'isActive', 'lastUpdate']);
      allow update: if isSignedIn()
                            && tanodId == request.auth.uid
                            && isValidPatrol(incoming())
                            && incoming().id == existing().id
                            && incoming().tanodId == existing().tanodId;
      allow read: if isSignedIn(); 
      allow delete: if false;
    }

    // --- Witness Requests ---
    function isValidWitnessRequest(data) {
        return data.alertId is string
               && data.witnessUserId is string
               && data.status is string;
    }

    match /alerts/{alertId}/witness_requests/{witnessId} {
      allow create: if isSignedIn()
                    && isValidId(witnessId)
                    && isValidWitnessRequest(incoming())
                    && exists(/databases/$(database)/documents/alerts/$(alertId));
      allow read: if isSignedIn() 
                  && (resource.data.witnessUserId == request.auth.uid || get(/databases/$(database)/documents/alerts/$(alertId)).data.residentId == request.auth.uid);
      allow delete: if false;
    }

    // --- Broadcasts Collection ---
    function isValidBroadcast(data) {
        return data.adminId is string
               && data.type is string
               && data.message is string
               && data.message.size() >= 1 && data.message.size() <= 500;
    }

    match /broadcasts/{broadcastId} {
      allow create: if isSignedIn()
                    && isValidId(broadcastId)
                    && isValidBroadcast(incoming())
                    && incoming().adminId == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isSignedIn()
                    && incoming().adminId == existing().adminId
                    && incoming().diff(existing()).affectedKeys().hasOnly(['isActive', 'expiresAt']);
      allow delete: if false;
    }
  }
}
