rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users - Strict ownership
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.token.role in ['admin', 'superadmin', 'tanod'];
    }

    // Alerts (SOS) - Core safety feature
    match /alerts/{alertId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.role in ['tanod', 'admin', 'superadmin']
      );
      allow update: if request.auth != null && 
        request.auth.token.role in ['tanod', 'admin', 'superadmin'];
    }

    // SMS Logs (Twilio)
    match /smsLogs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && request.auth.token.role in ['admin', 'superadmin'];
    }

    // Tanod Locations (Real-time tracking)
    match /tanodLocations/{tanodId} {
      allow create, update: if request.auth != null && request.auth.uid == tanodId;
      allow read: if request.auth != null && request.auth.token.role in ['tanod', 'admin', 'superadmin'];
    }

    // System Settings
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role in ['admin', 'superadmin'];
    }

    // Default deny (Security First)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
