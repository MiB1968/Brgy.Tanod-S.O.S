{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "name", "role", "email", "status"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Emergency alert",
      "type": "object",
      "properties": {
        "residentId": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["residentId", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Emergency alerts"
    }
  }
}
