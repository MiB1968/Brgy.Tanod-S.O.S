{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["resident", "tanod", "admin"] }
      },
      "required": ["id", "email", "role"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Emergency SOS alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "residentId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved", "pending"] },
        "description": { "type": "string" }
      },
      "required": ["id", "residentId", "type", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Emergency alerts"
    }
  }
}
