{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Emergency SOS Alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "residentId": { "type": "string" },
        "residentName": { "type": "string" },
        "residentMobile": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string" },
        "updatedAt": { "type": "string" },
        "location": { "type": "object" },
        "customMessage": { "type": "string" },
        "aiAnalysis": { "type": "object" },
        "isManualLocation": { "type": "boolean" },
        "assignedTo": { "type": "string" },
        "assignedToName": { "type": "string" },
        "respondedBy": { "type": "string" },
        "respondedByName": { "type": "string" },
        "respondedAt": { "type": "string" },
        "resolvedAt": { "type": "string" },
        "resolutionNotes": { "type": "string" },
        "responderNotes": { "type": "string" }
      }
    },
    "Incident": {
        "title": "Incident",
        "description": "Patrol incident report",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "alertId": { "type": "string" },
            "tanodId": { "type": "string" },
            "tanodName": { "type": "string" },
            "timestamp": { "type": "string" },
            "location": { "type": "string" },
            "type": { "type": "string" },
            "description": { "type": "string" },
            "personsInvolved": { "type": "string" },
            "actionsTaken": { "type": "string" },
            "status": { "type": "string" }
        }
    },
    "PatrolLocation": {
        "title": "PatrolLocation",
        "description": "Tanod patrol location",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "tanodId": { "type": "string" }
        }
    },
    "WitnessRequest": {
        "title": "WitnessRequest",
        "description": "Request for nearby neighbors to witness/assist",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "alertId": { "type": "string" },
            "witnessUserId": { "type": "string" },
            "status": { "type": "string" }
        }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Secure message within an SOS alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderRole": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["senderId", "senderRole", "message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/alerts/{alertId}": { "schema": "Alert", "description": "SOS Alerts" },
    "/incidents/{incidentId}": { "schema": "Incident", "description": "Incident reports" },
    "/patrols/{tanodId}": { "schema": "PatrolLocation", "description": "Live patrol locations" },
    "/shifts/{shiftId}": { "schema": "Shift", "description": "Duty schedules" },
    "/alerts/{alertId}/witness_requests/{witnessId}": { "schema": "WitnessRequest", "description": "Real-time witness circle notifications" },
    "/alerts/{alertId}/messages/{messageId}": { "schema": "ChatMessage", "description": "Tactical chat messages" },
    "/system_broadcasts/{broadcastId}": { "schema": "object", "description": "Global emergency broadcasts" },
    "/broadcasts/{broadcastId}": { "schema": "object", "description": "Community broadcasts" },
    "/patrol_sessions/{sessionId}": { "schema": "object", "description": "Active session tracking" },
    "/tanod_activity_logs/{logId}": { "schema": "object", "description": "Tanod duty activity" },
    "/system_logs/{logId}": { "schema": "object", "description": "Security and audit logs" },
    "/audit_logs/{logId}": { "schema": "object", "description": "Operational audit trail" }
  }
}
