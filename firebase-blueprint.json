{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["resident", "tanod", "admin"] }
      },
      "required": ["id", "email", "role"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Emergency SOS alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "residentId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "resolved", "pending"] },
        "description": { "type": "string" }
      },
      "required": ["id", "residentId", "type", "status"]
    },
    "TanodLocation": {
      "title": "TanodLocation",
      "description": "Real-time location and status of a patrolling Tanod",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "accuracy": { "type": "number" },
        "speed": { "type": "number" },
        "heading": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["available", "on_patrol", "responding", "offline"] },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "lat", "lng", "timestamp", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "Emergency alerts"
    },
    "/tanod_locations/{userId}": {
      "schema": "TanodLocation",
      "description": "Real-time Tanod GPS location and status logs"
    }
  }
}
