{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Emergency SOS Alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "residentId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "string" },
        "residentName": { "type": "string" }
      }
    },
    "Incident": {
        "title": "Incident",
        "description": "Patrol incident report",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "alertId": { "type": "string" },
            "tanodId": { "type": "string" },
            "tanodName": { "type": "string" },
            "timestamp": { "type": "string" },
            "location": { "type": "string" },
            "type": { "type": "string" },
            "description": { "type": "string" },
            "personsInvolved": { "type": "string" },
            "actionsTaken": { "type": "string" },
            "status": { "type": "string" }
        }
    },
    "PatrolLocation": {
        "title": "PatrolLocation",
        "description": "Tanod patrol location",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "tanodId": { "type": "string" }
        }
    },
    "WitnessRequest": {
        "title": "WitnessRequest",
        "description": "Request for nearby neighbors to witness/assist",
        "type": "object",
        "properties": {
            "id": { "type": "string" },
            "alertId": { "type": "string" },
            "witnessUserId": { "type": "string" },
            "status": { "type": "string" }
        }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/alerts/{alertId}": { "schema": "Alert", "description": "SOS Alerts" },
    "/incidents/{incidentId}": { "schema": "Incident", "description": "Incident reports" },
    "/patrols/{tanodId}": { "schema": "PatrolLocation", "description": "Live patrol locations" },
    "/alerts/{alertId}/witness_requests/{witnessId}": { "schema": "WitnessRequest", "description": "Real-time witness circle notifications" }
  }
}
