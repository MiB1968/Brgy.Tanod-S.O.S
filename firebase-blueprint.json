{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["resident", "tanod", "admin"] },
        "status": { "type": "string" }
      },
      "required": ["uid", "email", "role"]
    },
    "Alert": {
      "title": "Alert",
      "description": "Emergency SOS Alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "residentId": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/alerts/{alertId}": { "schema": "Alert", "description": "SOS Alerts" }
  }
}
