{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": [
    "src/server.ts",
    "src/server/**/*.ts",
    "src/release.d.ts"
  ],
  "exclude": [
    "src/**/*.tsx",
    "src/tests/**",
    "dist",
    "node_modules"
  ]
}
