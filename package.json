{
  "name": "brgy-tanod-sos",
  "private": true,
  "version": "1.0.0",
  "description": "Mobile-first emergency response platform for Philippine barangays",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "prebuild": "node scripts/generate-icons.cjs && node scripts/generate-sentry-release.cjs",
    "icons": "node scripts/generate-icons.cjs",
    "build": "npx rimraf dist && npm run prebuild && npx vite build --mode production && npx esbuild src/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "functions:build": "cd functions && npm run build",
    "cleanup": "bash scripts/cleanup.sh",
    "clean": "rimraf dist",
    "typecheck:client": "tsc -p tsconfig.client.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lint": "npm run typecheck:client && npm run typecheck:server",
    "check": "npm run lint && npm test && npm run build",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx src/server/db/migrate.ts"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@capacitor/background-runner": "^3.0.0",
    "@capacitor/core": "^8.3.4",
